# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_here_change_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here_change_in_production

# Database Configuration
# Option 1: Use DATABASE_URL (for Neon or other cloud providers)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Option 2: Use individual database connection variables (like HandyHub)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=mjnutrafit

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# MJNutraFit AI Coach (Python service — same pattern as EduNavigator)
AI_SERVICE_URL=http://localhost:8000
